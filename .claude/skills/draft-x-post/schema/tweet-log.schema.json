{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StreamerHub Tweet Log (JSONL line schema)",
  "type": "object",
  "required": [
    "date",
    "topic",
    "variant",
    "text"
  ],
  "properties": {
    "date": {
      "type": "string",
      "description": "YYYY-MM-DD"
    },
    "topic": {
      "type": "string"
    },
    "variant": {
      "type": "string",
      "description": "A/B/C, short/thread/poll, etc."
    },
    "text": {
      "type": "string"
    },
    "hashtags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cta": {
      "type": "string"
    },
    "link": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "source_urls": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "review": {
      "type": "object",
      "properties": {
        "creative": {
          "type": "string"
        },
        "algorithm": {
          "type": "string"
        },
        "legal": {
          "type": "string"
        }
      }
    },
    "generated_at": {
      "type": "string"
    }
  }
}
